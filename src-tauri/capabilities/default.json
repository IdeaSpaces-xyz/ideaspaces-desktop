{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/ideaspaces",
          "sidecar": true,
          "args": ["whoami", "--json"]
        },
        {
          "name": "binaries/ideaspaces",
          "sidecar": true,
          "args": ["power", "logout", "--json"]
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/ideaspaces",
          "sidecar": true,
          "args": ["login", "--json"]
        }
      ]
    },
    "shell:allow-kill"
  ]
}
